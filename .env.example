# Recursiv API key. Get one at https://recursiv.io/settings/api-keys
# Must have access to the Ticker project (AutoNation IR org)
RECURSIV_API_KEY=

# Optional: override API base URL (defaults to https://recursiv.io/api/v1)
# RECURSIV_API_BASE_URL=

# Agent ID for the IR Quote Drafter agent (created on Recursiv)
# Create this agent with a CEO-voice system prompt, then paste the UUID here.
TICKER_QUOTE_AGENT_ID=
